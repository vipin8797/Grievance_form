<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Submit your grievances and complaints securely to Starex University. Our online grievance redressal system ensures your voices are heard and resolved efficiently.">
<meta name="keywords" content="Starex University, Grievance Form, Complaint Registry, Student Support, Staff Grievance, Online Complaint Portal">
<meta name="author" content="Starex University IT Department">
<meta name="robots" content="index, follow">

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website">
<meta property="og:title" content="Starex Grievance & Complaint Redressal Portal">
<meta property="og:description" content="Submit and track grievances securely. Our system ensures dynamic reviews and fast resolutions.">
<meta property="og:image" content="https://upload.wikimedia.org/wikipedia/en/6/65/Starex_University_logo.png">

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:title" content="Starex Grievance & Complaint Redressal Portal">
<meta property="twitter:description" content="Submit and track grievances securely. Our system ensures dynamic reviews and fast resolutions.">

<link rel="stylesheet" href="style.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
<link rel="icon" type="image/png" href="https://upload.wikimedia.org/wikipedia/en/6/65/Starex_University_logo.png">

<title>Starex Grievance Form</title>
</head>

<body>

<%- include("includes/flash.ejs") %>

<div class="container" role="main">

<h2>Starex Grievance / Complaint Form</h2>
<form action="/submit" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate aria-label="Grievance Submission Form">

<!-- CATEGORY -->
<div class="section" role="group" aria-labelledby="categoryHeading">
<h3 id="categoryHeading">Complaint Category</h3>

<label for="category" class="form-label d-none">Select Complaint Category</label>
<select id="category" name="category" class="form-select" aria-required="true" required>
<option value="">Select Category</option>
<option>General</option>
<option>Ragging</option>
<option>Caste Discrimination</option>
<option>Sexual Harassment</option>
<option>Examination</option>
<option>Minority Community</option>
</select>

<div class="invalid-feedback" role="alert">
Please select a category.
</div>
</div>

<!-- ROLE -->
<div class="section" role="group" aria-labelledby="roleHeading">
<h3 id="roleHeading">Who Are You?</h3>

<label for="role" class="form-label d-none">Select your role</label>
<select id="role" name="role" class="form-select" aria-required="true" required>
<option value="">Select</option>
<option value="student">Student</option>
<option value="staff">Staff</option>
</select>

<div class="invalid-feedback" role="alert">
Please select your role.
</div>
</div>

<!-- PERSONAL -->
<div class="section" role="group" aria-labelledby="personalHeading">
<h3 id="personalHeading">Personal Information</h3>

<div class="grid">

<div>
<label for="name" class="form-label d-none">Full Name</label>
<input id="name" name="name" class="form-control" placeholder="Full Name *" aria-required="true" required>
<div class="invalid-feedback" role="alert">Name required.</div>
</div>

<div>
<label for="fatherName" class="form-label d-none">Father's Name</label>
<input id="fatherName" name="fatherName" class="form-control" placeholder="Father's Name *" aria-required="true" required>
<div class="invalid-feedback" role="alert">Father name required.</div>
</div>

<div>
<label for="department" class="form-label d-none">Department</label>
<input id="department" name="department" class="form-control" placeholder="Department *" aria-required="true" required>
<div class="invalid-feedback" role="alert">Department required.</div>
</div>

</div>
</div>

<!-- STUDENT INFO -->
<div class="section" id="studentFields" role="group" aria-labelledby="studentHeading" style="display: none;">

<h3 id="studentHeading">Academic Information (Students Only)</h3>

<div class="grid">

<div>
<label for="programme" class="form-label d-none">Programme</label>
<input id="programme" name="programme" class="form-control" placeholder="Programme">
</div>

<div>
<label for="batch" class="form-label d-none">Batch of Admission</label>
<input id="batch" name="batch" class="form-control" placeholder="Batch of Admission">
</div>

<div>
<label for="semester" class="form-label d-none">Semester</label>
<input id="semester" name="semester" class="form-control" placeholder="Semester">
</div>

</div>
</div>

<!-- CONTACT -->
<div class="section" role="group" aria-labelledby="contactHeading">
<h3 id="contactHeading">Contact Details</h3>

<div class="mb-3">
<label for="address" class="form-label d-none">Address</label>
<textarea id="address" name="address" class="form-control" placeholder="Address *" aria-required="true" required></textarea>
<div class="invalid-feedback" role="alert">Address required.</div>
</div>

<div class="grid">

<div>
<label for="state" class="form-label d-none">State</label>
<input id="state" name="state" class="form-control" placeholder="State *" aria-required="true" required>
<div class="invalid-feedback" role="alert">State required.</div>
</div>

<div>
<label for="city" class="form-label d-none">City</label>
<input id="city" name="city" class="form-control" placeholder="City *" aria-required="true" required>
<div class="invalid-feedback" role="alert">City required.</div>
</div>

<div>
<label for="pincode" class="form-label d-none">Pin Code</label>
<input id="pincode" name="pincode" class="form-control" placeholder="Pin Code *" aria-required="true" required>
<div class="invalid-feedback" role="alert">Pincode required.</div>
</div>

<div>
<label for="contact" class="form-label d-none">Contact Number</label>
<input id="contact" name="contact" class="form-control" placeholder="Contact Number *" aria-required="true" required>
<div class="invalid-feedback" role="alert">Contact number required.</div>
</div>

</div>
</div>

<!-- COMPLAINT -->
<div class="section" role="group" aria-labelledby="complaintHeading">
<h3 id="complaintHeading">Complaint Details</h3>

<label for="message" class="form-label d-none">Describe complaint</label>
<textarea id="message" name="message" class="form-control" placeholder="Describe complaint *" aria-required="true" required></textarea>
<div class="invalid-feedback" role="alert">Complaint message required.</div>

</div>

<!-- EVIDENCE -->
<div class="section" role="group" aria-labelledby="evidenceHeading">
<h3 id="evidenceHeading">Evidence Upload</h3>

<i class="d-block mb-2 text-muted">max size 100 MB & max 5 file at once.</i>

<label for="evidenceFiles" class="form-label d-none">Upload evidence files</label>
<input type="file" id="evidenceFiles" name="evidenceFiles" class="form-control" multiple aria-describedby="evidenceHelp">
<div id="evidenceHelp" class="form-text d-none">Upload up to 5 documents or images under 100 MB total.</div>

<div class="my-3 text-center text-muted">OR</div>

<label for="evidenceUrl" class="form-label">Paste Evidence URL</label>
<input type="url" id="evidenceUrl" name="evidenceUrl" class="form-control" placeholder="https://example.com/file">

</div>

<button type="submit" class="btn btn-primary mt-3" aria-label="Submit Complaint Form">
Submit Complaint
</button>

</form>


</div>




<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<script>
    (() => {
        const forms = document.querySelectorAll(".needs-validation");
        const roleSelect = document.getElementById("role");
        const studentFields = document.getElementById("studentFields");

        roleSelect.addEventListener("change", function() {
            if (this.value === "student") {
                studentFields.style.display = "block";
            } else {
                studentFields.style.display = "none";
            }
        });

        Array.from(forms).forEach(form => {
            form.addEventListener("submit", event => {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add("was-validated");
            });
        });
    })();
</script>


</body>
</html>
